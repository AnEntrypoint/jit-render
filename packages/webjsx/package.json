{
  "name": "jit-render",
  "version": "0.1.3",
  "license": "Apache-2.0",
  "description": "Generative UI renderer using webjsx. No React, no Tailwind — Web Standards only.",
  "keywords": [
    "json",
    "ui",
    "webjsx",
    "web-components",
    "ai",
    "generative-ui",
    "llm",
    "renderer",
    "streaming"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnEntrypoint/jit-render.git",
    "directory": "packages/webjsx"
  },
  "homepage": "https://github.com/AnEntrypoint/jit-render",
  "bugs": {
    "url": "https://github.com/AnEntrypoint/jit-render/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./catalog": {
      "types": "./dist/catalog.d.ts",
      "import": "./dist/catalog.mjs",
      "require": "./dist/catalog.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@json-render/core": "workspace:*",
    "webjsx": "^0.0.73",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@internal/typescript-config": "workspace:*",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  }
}
